{
    "compilerOptions": {
        "target": "es2016",
        "module": "commonjs",
        "paths": {
            "@network/*": [
                "./src/network/*"
            ],
            "@core/*": [
                "./src/core/*"
            ],
            "@utils/*": [
                "./src/utils/constants/*",
                "./src/utils/core/*",
                "./src/utils/utils/*",
                "./src/utils/*"
            ]
        },
        "types": [
            "node"
        ],
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true
    }
}